{
  "name": "course-library",
  "version": "1.0.0",
  "description": "Dynamic Course Library — auto-syncs from Google Drive twice daily",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "node server.js",
    "sync":       "node sync.js",
    "sync:full":  "node sync.js --full",
    "sync:cat":   "node sync.js --cat"
  },
  "dependencies": {
    "express":    "^4.18.2",
    "compression":"^1.7.4",
    "node-cron":  "^3.0.3"
  }
}
